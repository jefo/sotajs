---
interface Props {
  question: string;
  answer: string;
  isOpen: boolean;
  onClick: () => void;
}
---

<div class="border border-[var(--color-border-subtle)] group">
  <button
    class="w-full px-6 py-5 flex items-center justify-between text-left hover:bg-[var(--color-surface-soft)] transition-colors"
    onclick={Props.onClick}
    aria-expanded={Props.isOpen}
  >
    <span class="font-semibold text-[var(--text-high)] pr-8">{Props.question}</span>
    <svg 
      class={`w-5 h-5 text-[var(--text-medium)] transition-transform duration-300 ${Props.isOpen ? 'rotate-180' : ''}`}
      fill="none" 
      stroke="currentColor" 
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div 
    class={`overflow-hidden transition-all duration-300 ${Props.isOpen ? 'max-h-96 opacity-100' : 'max-h-0 opacity-0'}`}"
  >
    <div class="px-6 pb-5 text-[var(--text-medium)] leading-relaxed" set:html={Props.answer} />
  </div>
</div>
