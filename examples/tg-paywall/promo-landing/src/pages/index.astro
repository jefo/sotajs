---
import Layout from '../layouts/Layout.astro';
import { ShieldCheck, Cpu, Globe, Zap, Layers } from 'lucide-astro';
---

<Layout>
	<main class="max-w-6xl mx-auto px-6">
		<!-- HERO SECTION: The Star of the Show -->
		<section class="py-24 md:py-40 grid md:grid-cols-2 gap-16 items-center">
			<div>
				<div class="secondary-label mb-4">Infrastructure-as-a-Service</div>
				<h1 class="text-5xl md:text-7xl font-extrabold mb-8 leading-[1.1]">
					Engineering access control for <span class="text-[var(--color-brand-primary)]">Telegram experts.</span>
				</h1>
				<p class="text-xl mb-10 max-w-lg">
					A professional paywall infrastructure built on SotaJS. Secure, provider-agnostic, and designed for high-ticket expert communities.
				</p>
				<div class="flex gap-4">
					<a href="#showcase" class="bg-[var(--color-brand-primary)] text-white px-8 py-4 rounded-sm font-semibold hover:opacity-90 transition-all">
						View Showcase
					</a>
					<a href="https://github.com/maxdev1/sotajs" class="border border-[var(--color-border-subtle)] px-8 py-4 rounded-sm font-semibold hover:bg-[var(--color-surface-soft)] transition-all">
						Documentation
					</a>
				</div>
			</div>

			<!-- STAR OF THE SHOW: Stylized Technical Component -->
			<div class="relative group">
				<div class="absolute -inset-4 bg-[var(--color-brand-primary)] opacity-[0.03] rounded-3xl group-hover:opacity-[0.05] transition-opacity"></div>
				<div class="relative bg-white border border-[var(--color-border-subtle)] p-8 rounded-sm shadow-2xl overflow-hidden">
					<!-- Visual Rhyme: Coding Grid -->
					<div class="absolute top-0 right-0 w-32 h-32 opacity-5 pointer-events-none">
						<div class="grid grid-cols-4 gap-2">
							<div class="w-full h-8 bg-black"></div>
							<div class="w-full h-8 bg-black"></div>
							<div class="w-full h-8 bg-black"></div>
							<div class="w-full h-8 bg-black"></div>
							<div class="w-full h-8 bg-black"></div>
							<div class="w-full h-8 bg-black"></div>
							<div class="w-full h-8 bg-black"></div>
							<div class="w-full h-8 bg-black"></div>
						</div>
					</div>
					
					<div class="font-mono text-sm opacity-40 mb-6 border-b border-[var(--color-border-subtle)] pb-4 uppercase tracking-widest">
						Paywall Core v1.0
					</div>
					
					<div class="space-y-4">
						<div class="flex items-center gap-4 p-4 bg-[var(--color-surface-soft)] rounded-sm">
							<div class="w-2 h-2 rounded-full bg-[var(--color-brand-primary)] animate-pulse"></div>
							<div class="flex-1 font-mono text-xs uppercase tracking-widest">System Operational</div>
						</div>
						<div class="grid grid-cols-2 gap-4">
							<div class="p-4 border border-[var(--color-border-subtle)] rounded-sm">
								<div class="secondary-label text-[10px] mb-1">Transactions</div>
								<div class="font-bold">Verified</div>
							</div>
							<div class="p-4 border border-[var(--color-border-subtle)] rounded-sm">
								<div class="secondary-label text-[10px] mb-1">State</div>
								<div class="font-bold">Consistent</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FEATURES: Trusted Providers -->
		<section id="features" class="py-20 border-t border-[var(--color-border-subtle)]">
			<div class="grid md:grid-cols-3 gap-12">
				<div class="md:col-span-1">
					<h2 class="text-3xl font-bold mb-6 italic tracking-tighter">Multi-provider architecture.</h2>
					<p class="text-sm opacity-80">One core logic. Multiple built-in payment adapters. Switch providers via environment variables without touching the business domain.</p>
				</div>
				<div class="md:col-span-2 grid grid-cols-2 sm:grid-cols-3 gap-4">
					{['YooKassa', 'Robokassa', 'Prodamus', 'Stripe', 'CryptoPay', 'LocalMock'].map(provider => (
						<div class="p-6 border border-[var(--color-border-subtle)] bg-[var(--color-surface-soft)]/30 rounded-sm hover:border-[var(--color-brand-primary)] transition-colors group">
							<div class="font-mono font-bold text-xs mb-2 group-hover:text-[var(--color-brand-primary)] uppercase tracking-widest opacity-80">{provider}</div>
							<div class="text-[9px] uppercase tracking-widest opacity-40">Module Configured</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ARCHITECTURE: Engineering Focus -->
		<section id="architecture" class="py-32">
			<div class="bg-black text-white p-12 md:p-24 rounded-sm relative overflow-hidden">
				<div class="absolute inset-0 opacity-10 bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
				
				<div class="relative z-10 grid md:grid-cols-2 gap-20">
					<div>
						<h2 class="text-4xl font-bold mb-12 text-white italic">The SotaJS Advantage.</h2>
						<ul class="space-y-8">
							<li class="flex gap-6">
								<Cpu class="text-[var(--color-brand-primary)] shrink-0 w-8 h-8" />
								<div>
									<div class="font-bold mb-2 text-lg">Rich Domain Aggregates</div>
									<p class="text-white/50 text-sm leading-relaxed">No anemic models. All business invariants are enforced within the domain layer, preventing invalid states physically.</p>
								</div>
							</li>
							<li class="flex gap-6">
								<Layers class="text-[var(--color-brand-primary)] shrink-0 w-8 h-8" />
								<div>
									<div class="font-bold mb-2 text-lg">Clean Persistence Isolation</div>
									<p class="text-white/50 text-sm leading-relaxed">Infrastructure is just a detail. Your business logic remains pure, testable, and completely detached from the database or API specifics.</p>
								</div>
							</li>
						</ul>
					</div>
					<div class="border-l border-white/10 pl-12 hidden md:block">
						<div class="font-mono text-[10px] text-white/30 mb-10 tracking-[0.4em] uppercase">Technical Stack Overview</div>
						<div class="space-y-6 font-mono text-sm">
							<div class="flex justify-between border-b border-white/10 pb-3">
								<span class="text-white/30 uppercase text-[10px]">Logic Framework</span>
								<span class="text-white/80">SotaJS Core</span>
							</div>
							<div class="flex justify-between border-b border-white/10 pb-3">
								<span class="text-white/30 uppercase text-[10px]">Language</span>
								<span class="text-white/80">TypeScript 5.x</span>
							</div>
							<div class="flex justify-between border-b border-white/10 pb-3">
								<span class="text-white/30 uppercase text-[10px]">Engine</span>
								<span class="text-white/80">Bun 1.3+</span>
							</div>
							<div class="flex justify-between border-b border-white/10 pb-3">
								<span class="text-white/30 uppercase text-[10px]">Integration</span>
								<span class="text-white/80">Webhooks / RSA</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- SHOWCASE: Placeholder for high-quality visuals -->
		<section id="showcase" class="py-20">
			<div class="text-center mb-20">
				<h2 class="text-4xl font-bold mb-4">Implementation Showcase.</h2>
				<p class="text-[var(--text-medium)]">Real-world flow of the Product Accelerator bot.</p>
			</div>
			
			<div class="grid md:grid-cols-2 gap-8">
				<div class="aspect-[9/16] bg-[var(--color-surface-soft)] border border-[var(--color-border-subtle)] rounded-sm flex items-center justify-center p-12 group hover:border-[var(--color-brand-primary)] transition-all">
					<div class="text-center">
						<div class="secondary-label mb-4 opacity-20">User Flow Video</div>
						<div class="w-16 h-16 border border-[var(--color-border-subtle)] rounded-full flex items-center justify-center mx-auto group-hover:scale-110 transition-transform">
							<Zap class="w-6 h-6 text-[var(--color-brand-primary)]" />
						</div>
					</div>
				</div>
				<div class="space-y-8">
					<div class="h-1/2 bg-[var(--color-surface-soft)] border border-[var(--color-border-subtle)] rounded-sm p-10 flex flex-col justify-end relative overflow-hidden">
						<div class="font-mono text-[10px] absolute top-6 right-6 opacity-20 uppercase tracking-widest">Dashboard Preview</div>
						<div class="font-bold text-xl mb-2 italic underline underline-offset-8 decoration-[var(--color-brand-primary)]">Real-time control.</div>
						<p class="text-sm">Manage participants, revenue streams, and automated expulsions from a single unified interface.</p>
					</div>
					<div class="h-1/2 bg-[var(--color-surface-soft)] border border-[var(--color-border-subtle)] rounded-sm p-10 flex flex-col justify-end relative overflow-hidden">
						<div class="font-mono text-[10px] absolute top-6 right-6 opacity-20 uppercase tracking-widest">API Interface</div>
						<div class="font-bold text-xl mb-2 italic underline underline-offset-8 decoration-[var(--color-brand-primary)]">Developer-First.</div>
						<p class="text-sm">Expose your paywall as a secure API for custom integrations with external LMS or marketing tools.</p>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
