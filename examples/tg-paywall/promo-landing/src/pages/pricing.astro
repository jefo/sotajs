---
import Layout from '../layouts/Layout.astro';
import { CheckCircle2, XCircle } from 'lucide-astro';

const plans = [
  {
    name: 'Self-Hosted',
    price: 'Free',
    description: 'For developers who want full control',
    features: [
      { text: 'Full source code access', included: true },
      { text: 'All payment providers', included: true },
      { text: 'Unlimited communities', included: true },
      { text: 'SQLite database', included: true },
      { text: 'Community support', included: true },
      { text: 'Documentation', included: true },
      { text: 'Priority support', included: false },
      { text: 'Custom integrations', included: false },
      { text: 'SLA guarantee', included: false },
    ],
    cta: 'Get Started',
    href: 'https://github.com/maxdev1/sotajs',
    popular: false,
  },
  {
    name: 'Managed',
    price: '$199/mo',
    description: 'For businesses that want hassle-free operation',
    features: [
      { text: 'Full source code access', included: true },
      { text: 'All payment providers', included: true },
      { text: 'Unlimited communities', included: true },
      { text: 'PostgreSQL database', included: true },
      { text: 'Priority email support', included: true },
      { text: 'Documentation', included: true },
      { text: 'Priority support', included: true },
      { text: 'Custom integrations', included: false },
      { text: 'SLA guarantee', included: false },
    ],
    cta: 'Start Trial',
    href: '#contact',
    popular: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    description: 'For agencies and large-scale deployments',
    features: [
      { text: 'Full source code access', included: true },
      { text: 'All payment providers', included: true },
      { text: 'Unlimited communities', included: true },
      { text: 'PostgreSQL database', included: true },
      { text: 'Priority email support', included: true },
      { text: 'Documentation', included: true },
      { text: 'Priority support', included: true },
      { text: 'Custom integrations', included: true },
      { text: 'SLA guarantee', included: true },
    ],
    cta: 'Contact Sales',
    href: '#contact',
    popular: false,
  },
];

const comparisonData = [
  {
    feature: 'Branding',
    selfHosted: 'Your brand',
    managed: 'Your brand',
    enterprise: 'Your brand',
  },
  {
    feature: 'Payment Providers',
    selfHosted: 'All (self-configured)',
    managed: 'All (pre-configured)',
    enterprise: 'Custom + All',
  },
  {
    feature: 'Database',
    selfHosted: 'SQLite',
    managed: 'PostgreSQL',
    enterprise: 'PostgreSQL + Replication',
  },
  {
    feature: 'Support',
    selfHosted: 'Community',
    managed: 'Priority Email',
    enterprise: '24/7 Dedicated',
  },
  {
    feature: 'Updates',
    selfHosted: 'Manual',
    managed: 'Automatic',
    enterprise: 'Automatic + Early Access',
  },
  {
    feature: 'Custom Development',
    selfHosted: 'Self-service',
    managed: 'Available',
    enterprise: 'Included',
  },
];
---

<Layout
  title="Pricing | TG Paywall Infrastructure - Transparent Plans for Every Scale"
  description="Choose the right plan for your needs. From free self-hosted to enterprise with full support. No hidden fees, no revenue share."
  canonicalURL="/pricing"
>
  <main>
    <!-- Header -->
    <section class="py-24 md:py-40 border-b border-[var(--color-border-subtle)] bg-[var(--color-surface-soft)]">
      <div class="max-w-4xl mx-auto px-6 text-center animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-brand-primary)]/10 rounded-full mb-8">
          <span class="secondary-label text-[10px] font-bold">Transparent Pricing</span>
        </div>
        <h1 class="text- balance mb-8 tracking-tight font-extrabold">
          Никаких процентов от <span class="gradient-text">вашей прибыли</span>.
        </h1>
        <p class="text-xl text-[var(--text-medium)] max-w-2xl mx-auto leading-relaxed">
          В отличие от других решений, которые берут 5-10% от оборота, мы предлагаем фиксированные тарифы. Вся прибыль остается у вас.
        </p>
      </div>
    </section>

    <!-- Pricing Cards -->
    <section class="py-24 md:py-40">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-10">
          {plans.map((plan) => (
            <div 
              class={`relative p-10 border flex flex-col transition-all duration-500 rounded-3xl ${
                plan.popular 
                  ? 'border-[var(--color-brand-primary)] shadow-premium scale-105 z-10 bg-white' 
                  : 'border-[var(--color-border-subtle)] bg-white hover:border-[var(--color-brand-primary)]/30 hover:shadow-xl'
              }`}
            >
              {plan.popular && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[var(--color-brand-primary)] text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">
                  Самый популярный
                </div>
              )}
              
              <div class="mb-8">
                <h3 class="text-2xl font-bold mb-3">{plan.name}</h3>
                <p class="text-[var(--text-medium)] text-sm leading-relaxed">{plan.description}</p>
              </div>
              
              <div class="mb-10">
                <span class="text-5xl font-display font-extrabold text-[var(--text-high)] tracking-tighter">{plan.price}</span>
                {plan.price !== 'Free' && plan.price !== 'Custom' && (
                  <span class="text-[var(--text-low)] font-medium text-lg ml-1">/мес</span>
                )}
              </div>
              
              <ul class="space-y-5 mb-12 flex-1">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3 text-sm">
                    {feature.included ? (
                      <CheckCircle2 class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
                    ) : (
                      <XCircle class="w-5 h-5 text-[var(--text-low)] shrink-0 mt-0.5" />
                    )}
                    <span class={feature.included ? 'text-[var(--text-high)] font-medium' : 'text-[var(--text-low)]'}>
                      {feature.text}
                    </span>
                  </li>
                ))}
              </ul>
              
              <a 
                href={plan.href}
                class={`w-full py-4 rounded-xl font-bold text-center transition-all ${
                  plan.popular
                    ? 'bg-[var(--color-brand-primary)] text-white hover:opacity-90 shadow-lg shadow-blue-200'
                    : 'bg-[var(--color-surface-soft)] text-[var(--text-high)] hover:bg-[var(--color-border-subtle)]'
                }`}
              >
                {plan.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="py-20 bg-[var(--color-surface-soft)] border-y border-[var(--color-border-subtle)]">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-12 text-center">Detailed Comparison</h2>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[var(--color-border-subtle)]">
                <th class="text-left py-4 px-6 font-semibold text-[var(--text-high)]">Feature</th>
                <th class="text-center py-4 px-6 font-semibold text-[var(--text-high)]">Self-Hosted</th>
                <th class="text-center py-4 px-6 font-semibold text-[var(--text-high)]">Managed</th>
                <th class="text-center py-4 px-6 font-semibold text-[var(--text-high)]">Enterprise</th>
              </tr>
            </thead>
            <tbody>
              {comparisonData.map((row, index) => (
                <tr class={index % 2 === 0 ? 'bg-white' : 'bg-white/50'}>
                  <td class="py-4 px-6 text-[var(--text-high)] font-medium">{row.feature}</td>
                  <td class="py-4 px-6 text-center text-[var(--text-medium)]">{row.selfHosted}</td>
                  <td class="py-4 px-6 text-center text-[var(--text-medium)]">{row.managed}</td>
                  <td class="py-4 px-6 text-center text-[var(--text-medium)]">{row.enterprise}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ROI Calculator -->
    <section class="py-20 md:py-32">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">
          See how much you'll save
        </h2>
        <p class="text-[var(--text-medium)] text-center mb-12 max-w-2xl">
          Compare our pricing to typical revenue-share models (5-10% of your revenue).
        </p>
        
        <div class="p-8 border border-[var(--color-border-subtle)] rounded-sm bg-[var(--color-surface-soft)]/30">
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-bold mb-4">Revenue-Share Model (10%)</h3>
              <div class="space-y-4">
                <div class="flex justify-between">
                  <span class="text-[var(--text-medium)]">$1,000/month revenue</span>
                  <span class="font-bold text-red-500">$100/month</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-medium)]">$10,000/month revenue</span>
                  <span class="font-bold text-red-500">$1,000/month</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-medium)]">$50,000/month revenue</span>
                  <span class="font-bold text-red-500">$5,000/month</span>
                </div>
                <div class="flex justify-between pt-4 border-t border-[var(--color-border-subtle)]">
                  <span class="text-[var(--text-medium)]">$100,000/month revenue</span>
                  <span class="font-bold text-red-500">$10,000/month</span>
                </div>
              </div>
            </div>
            
            <div>
              <h3 class="font-bold mb-4">TG Paywall (Managed)</h3>
              <div class="space-y-4">
                <div class="flex justify-between">
                  <span class="text-[var(--text-medium)]">$1,000/month revenue</span>
                  <span class="font-bold text-green-500">$199/month</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-medium)]">$10,000/month revenue</span>
                  <span class="font-bold text-green-500">$199/month</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-medium)]">$50,000/month revenue</span>
                  <span class="font-bold text-green-500">$199/month</span>
                </div>
                <div class="flex justify-between pt-4 border-t border-[var(--color-border-subtle)]">
                  <span class="text-[var(--text-medium)]">$100,000/month revenue</span>
                  <span class="font-bold text-green-500">$199/month</span>
                </div>
              </div>
            </div>
          </div>
          
          <div class="mt-8 p-6 bg-[var(--color-brand-primary)]/10 rounded-sm">
            <p class="text-center">
              <span class="font-bold text-[var(--color-brand-primary)]">
                At $50,000/month revenue, you save $4,801/month ($57,612/year)
              </span>
              <span class="text-[var(--text-medium)]"> compared to 10% revenue share.</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 border-t border-[var(--color-border-subtle)]">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-12 text-center">Common Questions</h2>
        
        <div class="space-y-4">
          <details class="group border border-[var(--color-border-subtle)] rounded-sm" open>
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="font-semibold text-[var(--text-high)] pr-8">Can I switch plans later?</span>
              <svg class="w-5 h-5 text-[var(--text-medium)] transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-[var(--text-medium)] leading-relaxed">
              Yes! You can upgrade from Self-Hosted to Managed or Enterprise at any time. We'll help you migrate your database and configure everything.
            </div>
          </details>
          
          <details class="group border border-[var(--color-border-subtle)] rounded-sm">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="font-semibold text-[var(--text-high)] pr-8">What payment methods do you accept?</span>
              <svg class="w-5 h-5 text-[var(--text-medium)] transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-[var(--text-medium)] leading-relaxed">
              We accept credit cards (Stripe), bank transfers, and cryptocurrency (USDT, BTC, TON) for Enterprise plans.
            </div>
          </details>
          
          <details class="group border border-[var(--color-border-subtle)] rounded-sm">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="font-semibold text-[var(--text-high)] pr-8">Is there a refund policy?</span>
              <svg class="w-5 h-5 text-[var(--text-medium)] transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-[var(--text-medium)] leading-relaxed">
              Yes, we offer a 30-day money-back guarantee for Managed and Enterprise plans. If you're not satisfied, we'll refund your payment, no questions asked.
            </div>
          </details>
        </div>
      </div>
    </section>
  </main>
</Layout>
