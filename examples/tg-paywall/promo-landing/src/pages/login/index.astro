---
import Layout from '../../layouts/Layout.astro';
import { LogIn } from 'lucide-astro';
---

<Layout
  title="Вход в личный кабинет | TG Paywall"
  description="Войдите в личный кабинет TG Paywall для управления подписками и настройками."
  canonicalURL="/login"
>
  <main>
    <!-- Login Section -->
    <section class="py-20 md:py-32">
      <div class="container max-w-md">
        <div class="card p-8">
          <div class="text-center mb-8">
            <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-[var(--color-brand-primary)]/10 flex items-center justify-center">
              <LogIn class="w-8 h-8 text-[var(--color-brand-primary)]" />
            </div>
            <h1 class="text-2xl font-bold mb-2">Вход в кабинет</h1>
            <p class="text-[var(--text-medium)] text-sm">
              Введите email для входа в личный кабинет
            </p>
          </div>
          
          <form class="space-y-6" action="/api/login" method="POST">
            <div>
              <label for="email" class="block text-sm font-medium text-[var(--text-high)] mb-2">
                Email
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                placeholder="you@example.com"
                class="w-full px-4 py-3 border border-[var(--color-border-subtle)] rounded-lg focus:outline-none focus:border-[var(--color-brand-primary)] focus:ring-2 focus:ring-[var(--color-brand-primary)]/20 transition-all"
              />
            </div>
            
            <button type="submit" class="btn btn-primary w-full">
              Войти
            </button>
          </form>
          
          <div class="mt-6 text-center">
            <p class="text-sm text-[var(--text-medium)]">
              Нет аккаунта? <a href="#pricing" class="text-[var(--color-brand-primary)] font-medium hover:underline">Начать бесплатно</a>
            </p>
          </div>
          
          <div class="mt-8 pt-8 border-t border-[var(--color-border-subtle)]">
            <div class="text-center">
              <p class="text-xs text-[var(--text-low)] mb-4">Или войдите через</p>
              <div class="flex gap-3 justify-center">
                <a href="#" class="px-4 py-2 border border-[var(--color-border-subtle)] rounded-lg text-sm font-medium hover:bg-[var(--color-surface-soft)] transition-all">
                  Telegram
                </a>
                <a href="#" class="px-4 py-2 border border-[var(--color-border-subtle)] rounded-lg text-sm font-medium hover:bg-[var(--color-surface-soft)] transition-all">
                  Google
                </a>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Help Link -->
        <div class="text-center mt-8">
          <a href="/help" class="text-sm text-[var(--text-medium)] hover:text-[var(--color-brand-primary)] transition-colors">
            Нужна помощь со входом?
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
