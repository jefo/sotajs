          </div>
          
          <div>
            <h4 class="font-semibold mb-4">Компания</h4>
            <ul class="space-y-3">
              <li><a href="/about" class="text-sm text-[var(--text-medium)] hover:text-white transition-colors">О нас</a></li>
              <li><a href="/contact" class="text-sm text-[var(--text-medium)] hover:text-white transition-colors">Контакты</a></li>
