                <a href="/#how-it-works" class="block px-4 py-2.5 text-sm text-[var(--text-medium)] hover:bg-[var(--color-surface-soft)] hover:text-[var(--color-brand-primary)] transition-colors">
                  <span class="font-medium">Как работает</span>
                  <span class="block text-xs text-[var(--text-low)] mt-0.5">4 шага запуска</span>
