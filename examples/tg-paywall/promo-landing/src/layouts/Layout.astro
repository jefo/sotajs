          </div>

          <div>
            <h4 class="font-semibold mb-4">Продукт</h4>
            <ul class="space-y-3">
              <li><a href="/#features" class="text-sm text-[var(--text-medium)] hover:text-white transition-colors">Возможности</a></li>
              <li><a href="/pricing" class="text-sm text-[var(--text-medium)] hover:text-white transition-colors">Тарифы</a></li>
              <li><a href="/#how-it-works" class="text-sm text-[var(--text-medium)] hover:text-white transition-colors">Как работает</a></li>
