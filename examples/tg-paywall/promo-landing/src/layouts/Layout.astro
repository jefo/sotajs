          <a href="/help" class="block py-2 text-[var(--text-medium)] hover:text-[var(--color-brand-primary)]">Помощь</a>
          <a href="/faq" class="block py-2 text-[var(--text-medium)] hover:text-[var(--color-brand-primary)]">FAQ</a>
          <a href="/about" class="block py-2 text-[var(--text-medium)] hover:text-[var(--color-brand-primary)]">О нас</a>
          <a href="/contact" class="block py-2 text-[var(--text-medium)] hover:text-[var(--color-brand-primary)]">Контакты</a>
          <div class="pt-4 border-t border-[var(--color-border-subtle)] flex flex-col gap-3">
            <a href="/login" class="text-center py-2 text-[var(--text-medium)] hover:text-[var(--text-high)]">Войти</a>
