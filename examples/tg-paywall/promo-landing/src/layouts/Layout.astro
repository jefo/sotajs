            <span class="w-2 h-2 rounded-full bg-green-500 status-pulse shadow-[0_0_10px_rgba(34,197,94,0.4)]"></span>
            <span class="text-[10px] font-mono font-bold text-green-700 uppercase tracking-widest leading-none">System Online</span>
          </div>
          <span class="ml-1">TG<span class="text-[var(--color-brand-primary)]">Paywall</span></span>
